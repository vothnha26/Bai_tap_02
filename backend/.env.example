# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend Configuration (CORS)
FRONTEND_URL=http://localhost:5173

# Database (MongoDB)
# Production/Development URI
MONGODB_URI="mongodb://root:root_password@127.0.0.1:27017/baitap04_mongodb?authSource=admin"
# Test URI (used for npm test)
MONGODB_URI_TEST="mongodb://root:root_password@127.0.0.1:27017/baitap04_mongodb_test?authSource=admin"

# Redis
# Option 1: Full URL (preferred)
REDIS_URL="redis://localhost:6379"
# Option 2: Individual components (fallback)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Use in-memory Redis for testing or if no real Redis is available (Dev only)
USE_MEMORY_REDIS=false

# JWT Security
# Generate strong secrets (at least 32 characters)
JWT_ACCESS_SECRET=your_access_token_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_here_min_32_chars

# Email Configuration
# Option 1: Generic SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
# Option 2: Gmail Specific (backwards compatibility)
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_app_password_here

# Logging
# Levels: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info
